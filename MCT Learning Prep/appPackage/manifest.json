{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.26/MicrosoftTeams.schema.json",
    "manifestVersion": "1.26",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "{developerName}",
        "websiteUrl": "https://{websiteUrl}",
        "privacyUrl": "https://{privacyUrl}",
        "termsOfUseUrl": "https://{termsOfUseUrl}"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "MCT Learning Prep${{APP_NAME_SUFFIX}}",
        "full": "Full name for MCT Learning Prep"
    },
    "description": {
        "short": "Short description for MCT Learning Prep",
        "full": "Full description for MCT Learning Prep"
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "composeExtensions": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "copilotAgents": {
        "declarativeAgents": [            
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "validDomains": []
}